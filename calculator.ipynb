     "text": [
      "10 + 3  = 13\n",
      "10 - 3  = 7\n",
      "10 * 3  = 30\n",
      "10 / 3  = 3.3333\n",
      "10 // 3 = 3   ← floor division\n",
      "10 % 3  = 1    ← remainder\n",
      "10 ** 3 = 1000  ← power\n"
     ]
    }
   ],
   "source": [
    "a = 10\n",
    "b = 3\n",
    "\n",
    "print(f\"{a} + {b}  = {a + b}\")\n",
    "print(f\"{a} - {b}  = {a - b}\")\n",
    "print(f\"{a} * {b}  = {a * b}\")\n",
    "print(f\"{a} / {b}  = {a / b:.4f}\")\n",
    "print(f\"{a} // {b} = {a // b}   ← floor division\")\n",
    "print(f\"{a} % {b}  = {a % b}    ← remainder\")\n",
    "print(f\"{a} ** {b} = {a ** b}  ← power\")\n"
   ]
  },
